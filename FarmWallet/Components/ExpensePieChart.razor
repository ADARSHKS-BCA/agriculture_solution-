@using FarmWallet.Models

<MudPaper Elevation="3" Class="pa-4 rounded-lg d-flex flex-column align-center justify-center" Style="height: 100%;">
    <MudText Typo="Typo.h6" Class="mb-4">Expense Distribution</MudText>
    
    @if (Data != null && Data.Length > 0)
    {
        <MudChart T="double" ChartType="ChartType.Pie" InputData="@Data" InputLabels="@Labels" Width="200px" Height="200px" />
    }
    else
    {
        <MudText Typo="Typo.body2" Color="Color.Surface">No expense data available.</MudText>
    }
</MudPaper>

@code {
    [Parameter] public List<Transaction> Transactions { get; set; } = new();
    
    private double[] Data;
    private string[] Labels;

    protected override void OnParametersSet()
    {
        var expenses = Transactions
            .Where(t => t.Type == "Expense")
            .GroupBy(t => t.Category)
            .Select(g => new { Category = g.Key, Total = (double)g.Sum(t => t.Amount) })
            .ToList();

        if (expenses.Any())
        {
            Data = expenses.Select(e => e.Total).ToArray();
            Labels = expenses.Select(e => $"{e.Category} ({(e.Total / expenses.Sum(x => x.Total) * 100):F1}%)").ToArray();
        }
        else
        {
            Data = Array.Empty<double>();
            Labels = Array.Empty<string>();
        }
    }
}
