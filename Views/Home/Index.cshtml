@{
    ViewData["Title"] = "Home";
}
@model Agriculture.Models.CropAnalysisViewModel

<!-- Hero Section -->
<section class="hero-section">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8 text-center">
                <div class="hero-badge mb-3">
                    <i class="bi bi-stars me-1"></i>AI-Powered Analysis
                </div>
                <h1 class="hero-title">
                    AgriShield <span class="text-accent">AI</span>
                </h1>
                <p class="hero-tagline">Early Crop Disease Detection &amp; Risk Prediction</p>
                <p class="hero-desc mx-auto">
                    Upload a photo of your crop leaf and let our advanced AI instantly identify diseases,
                    assess environmental risks, and recommend targeted treatments — empowering farmers
                    with data-driven decisions.
                </p>
            </div>
        </div>
    </div>
</section>

<!-- Upload Section -->
<section class="py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8 col-xl-7">
                <div class="card upload-card">
                    <div class="card-body p-4 p-md-5">

                        <h2 class="h4 fw-bold text-center mb-1">
                            <i class="bi bi-cloud-arrow-up me-2 text-accent"></i>Analyze Your Crop
                        </h2>
                        <p class="text-muted text-center mb-4 small">Upload a clear photo of the affected leaf for best results</p>

                        <form asp-action="Analyze" method="post" enctype="multipart/form-data" id="analysisForm" novalidate>
                            <!-- Validation Summary -->
                            <div asp-validation-summary="ModelOnly" class="alert alert-danger small" role="alert"></div>

                            <!-- Drag & Drop Upload -->
                            <div class="mb-4">
                                <label class="form-label fw-semibold">
                                    <i class="bi bi-image me-1"></i>Crop Leaf Image <span class="text-danger">*</span>
                                </label>
                                <div class="drop-zone" id="dropZone">
                                    <div class="drop-zone-prompt" id="dropPrompt">
                                        <i class="bi bi-cloud-upload fs-1 text-accent"></i>
                                        <p class="mt-2 mb-1 fw-semibold">Drag &amp; drop your image here</p>
                                        <p class="small text-muted mb-2">or click to browse</p>
                                        <span class="badge bg-light text-muted">PNG, JPG, JPEG · Max 5 MB</span>
                                    </div>
                                    <img id="imagePreview" class="drop-zone-preview d-none" alt="Preview" />
                                    <button type="button" id="removeImage" class="btn btn-sm btn-outline-danger drop-zone-remove d-none">
                                        <i class="bi bi-x-lg"></i> Remove
                                    </button>
                                    <input type="file" name="ImageFile" id="imageInput"
                                           class="drop-zone-input" accept="image/*" />
                                </div>
                                <span asp-validation-for="ImageFile" class="text-danger small"></span>
                                <div id="fileError" class="text-danger small mt-1 d-none"></div>
                            </div>

                            <!-- Crop Selection -->
                            <div class="mb-4">
                                <label asp-for="CropType" class="form-label fw-semibold">
                                    <i class="bi bi-tree me-1"></i>Crop Type <span class="text-danger">*</span>
                                </label>
                                <select asp-for="CropType" class="form-select" id="cropSelect">
                                    <option value="" disabled selected>Select your crop...</option>
                                    <option value="Tomato">🍅 Tomato</option>
                                    <option value="Potato">🥔 Potato</option>
                                    <option value="Corn">🌽 Corn</option>
                                    <option value="Wheat">🌾 Wheat</option>
                                    <option value="Rice">🌾 Rice</option>
                                </select>
                                <span asp-validation-for="CropType" class="text-danger small"></span>
                            </div>

                            <!-- Region -->
                            <div class="row g-3 mb-4">
                                <div class="col-sm-6">
                                    <label asp-for="Country" class="form-label fw-semibold">
                                        <i class="bi bi-globe-americas me-1"></i>Country <span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="Country" class="form-control" placeholder="e.g. India" />
                                    <span asp-validation-for="Country" class="text-danger small"></span>
                                </div>
                                <div class="col-sm-6">
                                    <label asp-for="State" class="form-label fw-semibold">
                                        <i class="bi bi-geo-alt me-1"></i>State / Region
                                    </label>
                                    <input asp-for="State" class="form-control" placeholder="e.g. Maharashtra" />
                                    <span asp-validation-for="State" class="text-danger small"></span>
                                </div>
                            </div>

                            <!-- Submit -->
                            <button type="submit" class="btn btn-primary-agri btn-lg w-100" id="submitBtn">
                                <span id="submitText">
                                    <i class="bi bi-search me-2"></i>Analyze Crop Disease
                                </span>
                                <span id="submitSpinner" class="d-none">
                                    <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                    Processing...
                                </span>
                            </button>
                        </form>

                    </div>
                </div>

                <!-- Info Card -->
                <div class="card info-card mt-4">
                    <div class="card-body p-4">
                        <div class="row g-3 text-center">
                            <div class="col-4">
                                <i class="bi bi-lightning-charge fs-4 text-accent"></i>
                                <p class="small fw-semibold mb-0 mt-1">Instant Analysis</p>
                                <p class="x-small text-muted">Results in seconds</p>
                            </div>
                            <div class="col-4">
                                <i class="bi bi-bullseye fs-4 text-accent"></i>
                                <p class="small fw-semibold mb-0 mt-1">High Accuracy</p>
                                <p class="x-small text-muted">AI-powered detection</p>
                            </div>
                            <div class="col-4">
                                <i class="bi bi-prescription2 fs-4 text-accent"></i>
                                <p class="small fw-semibold mb-0 mt-1">Treatment Plans</p>
                                <p class="x-small text-muted">Organic &amp; chemical</p>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</section>
