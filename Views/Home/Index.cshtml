@{
    ViewData["Title"] = "Intelligent Agriculture Solutions";
}

<!-- Hero Parallax Section -->
<section class="hero-parallax d-flex align-items-center" style="min-height: 85vh; background-image: url('/images/agri_hero.png'); background-attachment: fixed; background-size: cover; background-position: center;">
    <div class="hero-bg-overlay"></div>
    <div class="container py-5">
        <div class="row align-items-center g-5">
            <!-- Left Header -->
            <div class="col-lg-6 mb-5 mb-lg-0 pb-lg-5">
                <div class="pe-xl-5 float-animation">
                    <div class="d-inline-flex align-items-center py-2 px-3 rounded-pill mb-4" style="background: rgba(255,255,255,0.15); backdrop-filter: blur(10px); border: 1px solid rgba(255,255,255,0.2);">
                        <i class="fa-solid fa-seedling text-accent fs-5 me-2"></i>
                        <span class="text-white fw-medium small tracking-wider text-uppercase">The Future of Farming</span>
                    </div>
                    <h1 class="display-3 fw-bold text-white mb-4 lh-base" style="letter-spacing: -1px;">
                        Cultivate Success with <span class="text-accent" style="font-style: italic;">Precision Intelligence</span>.
                    </h1>
                    <p class="lead text-white-50 mb-5 fs-5 lh-lg" style="max-width: 500px;">
                        Harness the power of AI to detect crop diseases early, secure your harvest, and forecast yield profitability seamlessly.
                    </p>
                    <div class="d-flex flex-wrap gap-3">
                        <a asp-area="" asp-controller="Scan" asp-action="Index" class="btn btn-primary-agri btn-lg px-5 py-3 rounded-pill grow-on-hover shadow-lg">
                            Analyze Crop Now <i class="bi bi-arrow-right ms-2"></i>
                        </a>
                        <a href="#features" class="btn btn-outline-light btn-lg px-4 py-3 rounded-pill grow-on-hover">
                            Discover Features
                        </a>
                    </div>
                </div>
            </div>

            <!-- Right Glassmorphism Data Cards (Seedlings) -->
            <div class="col-lg-6">
                <div class="row g-4 justify-content-center">
                    <!-- Feature Card 1 -->
                    <div class="col-sm-6">
                        <div class="hero-seedling-card text-center d-flex flex-column align-items-center">
                            <div class="rounded-circle d-flex align-items-center justify-content-center mb-4" style="width: 70px; height: 70px; background: rgba(111,163,84,0.2);">
                                <i class="fa-solid fa-leaf text-accent fs-2"></i>
                            </div>
                            <h4 class="text-white mb-3 fw-bold">Instant AI Detection</h4>
                            <p class="text-white-50 small mb-0 lh-lg">Identify foliar diseases in seconds by simply dragging and dropping a leaf image into our advanced neural network scanner.</p>
                        </div>
                    </div>
                    <!-- Feature Card 2 -->
                    <div class="col-sm-6 mt-sm-5">
                        <div class="hero-seedling-card text-center d-flex flex-column align-items-center">
                            <div class="rounded-circle d-flex align-items-center justify-content-center mb-4" style="width: 70px; height: 70px; background: rgba(111,163,84,0.2);">
                                <i class="fa-solid fa-wallet text-accent fs-2"></i>
                            </div>
                            <h4 class="text-white mb-3 fw-bold">Farm Wallet</h4>
                            <p class="text-white-50 small mb-0 lh-lg">Track your seasonal expenses and profits effortlessly with deep financial metrics directly mapped to your farm's health.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Interactive Embedded Scan Section -->
<section id="scan" class="py-5 bg-white" style="position: relative; z-index: 10;">
    <div class="container py-5">
        <div class="row mb-5 justify-content-center text-center">
            <div class="col-md-9 float-animation">
                <i class="fa-solid fa-microchip fs-1 mb-3" style="color: var(--agri-primary);"></i>
                <h2 class="fw-bold fs-1 mb-3" style="color: var(--agri-nav-bg); font-family: 'Playfair Display', serif;">Neural Crop Scanner</h2>
                <p class="text-muted fs-5 lh-lg" style="max-width: 700px; margin: 0 auto;">Enter the photo to scan below. Our AI computes foliar health, assesses risks, and calculates treatment pathways.</p>
            </div>
        </div>

        <div class="row justify-content-center mt-3">
            <div class="col-lg-8">
                <div class="card bg-white shadow-lg border-0 agri-card-rounded">
                    <div class="card-body p-4 p-md-5">
                        <form asp-controller="Scan" asp-action="Analyze" method="post" enctype="multipart/form-data" id="analysisFormHome" novalidate>
                            <!-- Drag & Drop Upload -->
                            <div class="mb-5">
                                <label class="form-label fw-bold" style="color: var(--agri-primary); font-family: 'Playfair Display', serif; font-size: 1.1rem;">
                                    Crop Leaf Image <span class="text-danger">*</span>
                                </label>
                                <div class="drop-zone agri-card-rounded text-center p-5 position-relative grow-on-hover" id="dropZoneHome" style="background-color: var(--agri-bg-subtle); border: 2px dashed var(--agri-accent) !important;">
                                    <div class="drop-zone-prompt" id="dropPromptHome">
                                        <i class="fa-solid fa-cloud-arrow-up fs-1 mb-3" style="color: var(--agri-accent);"></i>
                                        <h5 class="mb-2 fw-bold text-dark" style="font-family: 'Playfair Display', serif;">Drag &amp; drop your image here</h5>
                                        <p class="small text-muted mb-3">or click to browse from your device</p>
                                    </div>
                                    <img id="imagePreviewHome" class="img-fluid rounded-2 mt-3 d-none mx-auto" style="max-height: 250px;" alt="Preview" />
                                    <input type="file" name="ImageFile" id="imageInputHome" class="position-absolute w-100 h-100 top-0 start-0 opacity-0" accept="image/*" style="cursor: pointer;" required />
                                </div>
                            </div>

                            <!-- Crop Selection & Location Row -->
                            <div class="row g-3 mb-4">
                                <div class="col-md-6 mb-3 mb-md-0">
                                    <label class="form-label fw-bold" style="color: var(--agri-primary); font-family: 'Playfair Display', serif; font-size: 1.1rem;">
                                        Crop Variety <span class="text-danger">*</span>
                                    </label>
                                    <select name="CropType" class="form-select rounded-1 bg-light border-0" required>
                                        <option value="" disabled selected>Select crop...</option>
                                        <option value="Tomato">Tomato</option>
                                        <option value="Potato">Potato</option>
                                        <option value="Corn">Corn</option>
                                        <option value="Wheat">Wheat</option>
                                        <option value="Rice">Rice</option>
                                    </select>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label fw-bold" style="color: var(--agri-primary); font-family: 'Playfair Display', serif; font-size: 1.1rem;">
                                        Farm Location <span class="text-danger">*</span>
                                    </label>
                                    <div class="input-group">
                                        <input name="City" class="form-control rounded-start-1 bg-light border-0" placeholder="e.g. London" required />
                                        <button type="button" class="btn btn-light border" title="Get precise location">
                                            <i class="bi bi-geo-alt"></i>
                                        </button>
                                    </div>
                                    <input type="hidden" name="Latitude" />
                                    <input type="hidden" name="Longitude" />
                                </div>
                            </div>

                            <div class="d-grid mt-5 pt-3">
                                <button type="submit" class="btn btn-primary-agri btn-lg rounded-pill fw-bold tracking-wide grow-on-hover shadow-lg">
                                    Initialize AI Analysis
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        // Simple distinct script for the home page drag & drop
        const fileInput = document.getElementById('imageInputHome');
        const preview = document.getElementById('imagePreviewHome');
        const prompt = document.getElementById('dropPromptHome');

        fileInput.addEventListener('change', function() {
            if (this.files && this.files[0]) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    preview.src = e.target.result;
                    preview.classList.remove('d-none');
                    prompt.classList.add('d-none');
                }
                reader.readAsDataURL(this.files[0]);
            }
        });
    </script>
}
