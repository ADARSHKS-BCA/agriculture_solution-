@model Agriculture.Models.AnalysisResultViewModel
@{
    ViewData["Title"] = "Analysis Results";
    ViewData["ShowAnalyzeAgain"] = true;
}

<section class="py-5 result-section">
    <div class="container">

        @if (!string.IsNullOrEmpty(Model.InferenceError))
        {
            <div class="alert alert-warning alert-dismissible fade show mb-4" role="alert">
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <strong>Notice:</strong> @Model.InferenceError Results shown are simulated data.
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <!-- Result Header -->
        <div class="text-center mb-5 fade-in position-relative">
            <div class="hero-badge mb-3">
                <i class="bi bi-check-circle me-1"></i>Analysis Complete
            </div>
            <h1 class="h2 fw-bold d-inline-block align-middle mb-0">Disease Detection Report</h1>
            
            <div class="d-inline-flex align-items-center ms-3 align-middle bg-light rounded-pill px-3 py-1 border shadow-sm">
                <button class="btn btn-sm btn-link text-dark p-0 me-2 text-decoration-none" id="btnReplayAudio" title="Read Aloud">
                    <i class="bi bi-volume-up-fill fs-5"></i>
                </button>
                <select id="voiceSelect" class="form-select form-select-sm border-0 bg-transparent fw-medium ms-1" style="width: 140px; cursor: pointer; box-shadow: none;" title="Select Voice/Language">
                    <option value="">Default Voice</option>
                </select>
            </div>
            
            <p class="text-muted mt-3">Analysis results for your <strong>@Model.CropName</strong> sample</p>
        </div>

        <div class="row g-4">

            <!-- LEFT COLUMN -->
            <div class="col-lg-5">

                <!-- Uploaded Image Card -->
                <div class="card result-card fade-in" style="animation-delay: 0.1s;">
                    <div class="card-body p-4">
                        <h5 class="card-title fw-bold mb-3">
                            <i class="bi bi-image me-2 text-accent"></i>Uploaded Sample
                        </h5>
                        <div class="uploaded-image-wrapper mb-3">
                            <img src="@Model.ImagePath" alt="Uploaded Crop Image" class="img-fluid rounded-3 w-100" />
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <span class="badge bg-accent-subtle text-accent me-2">
                                    <i class="bi bi-tree me-1"></i>@Model.CropName
                                </span>
                            </div>
                            <div class="text-muted small">
                                <i class="bi bi-geo-alt me-1"></i>@Model.Region
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Disease Detection Card -->
                <div class="card result-card mt-4 fade-in" style="animation-delay: 0.2s;">
                    <div class="card-body p-4">
                        <h5 class="card-title fw-bold mb-3">
                            <i class="bi bi-bug me-2 text-danger"></i>Disease Detected
                        </h5>
                        <h3 class="fw-bold mb-3 disease-name">@Model.DiseaseName</h3>
                        <div class="mb-2 d-flex justify-content-between align-items-center">
                            <span class="fw-semibold small">Confidence Score</span>
                            <span class="badge bg-@Model.ConfidenceColor">
                                @Model.Confidence.ToString("F1")%
                            </span>
                        </div>
                        <div class="progress confidence-bar mb-3" style="height: 12px;">
                            <div class="progress-bar bg-@Model.ConfidenceColor progress-bar-striped progress-bar-animated"
                                 role="progressbar"
                                 style="width: @Model.Confidence%"
                                 aria-valuenow="@Model.Confidence"
                                 aria-valuemin="0"
                                 aria-valuemax="100">
                            </div>
                        </div>
                        <div class="alert alert-light border-0 small mb-0 d-flex align-items-start gap-2">
                            <i class="bi bi-info-circle text-primary mt-1"></i>
                            <span>
                                Confidence score indicates the system's certainty.
                                Scores above 80% are considered highly reliable.
                                Lower scores suggest further lab verification is recommended.
                            </span>
                        </div>
                    </div>
                </div>

            </div>

            <!-- RIGHT COLUMN -->
            <div class="col-lg-7">

                <!-- Weather Snapshot Card -->
                <div class="card result-card fade-in" style="animation-delay: 0.3s;">
                    <div class="card-body p-4">
                        <h5 class="card-title fw-bold mb-3">
                            <i class="bi bi-cloud-sun me-2 text-info"></i>Weather Conditions
                        </h5>
                        <div class="row g-3">
                            <div class="col-6 col-md-3">
                                <div class="weather-metric text-center p-3 rounded-3">
                                    <i class="bi bi-thermometer-half fs-3 text-danger"></i>
                                    <p class="fw-bold mb-0 mt-2">@Model.Temperature°C</p>
                                    <p class="x-small text-muted mb-0">Temperature</p>
                                </div>
                            </div>
                            <div class="col-6 col-md-3">
                                <div class="weather-metric text-center p-3 rounded-3">
                                    <i class="bi bi-droplet-half fs-3 text-primary"></i>
                                    <p class="fw-bold mb-0 mt-2">@Model.Humidity%</p>
                                    <p class="x-small text-muted mb-0">Humidity</p>
                                </div>
                            </div>
                            <div class="col-6 col-md-3">
                                <div class="weather-metric text-center p-3 rounded-3">
                                    <i class="bi bi-cloud-rain fs-3 text-info"></i>
                                    <p class="fw-bold mb-0 mt-2">@Model.Rainfall mm</p>
                                    <p class="x-small text-muted mb-0">Rainfall</p>
                                </div>
                            </div>
                            <div class="col-6 col-md-3">
                                <div class="weather-metric text-center p-3 rounded-3">
                                    <i class="bi bi-wind fs-3 text-success"></i>
                                    <p class="fw-bold mb-0 mt-2">@Model.WindSpeed km/h</p>
                                    <p class="x-small text-muted mb-0">Wind Speed</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Risk Assessment Card -->
                <div class="card result-card mt-4 fade-in" style="animation-delay: 0.4s;">
                    <div class="card-body p-4">
                        <h5 class="card-title fw-bold mb-3">
                            <i class="bi bi-exclamation-triangle me-2 text-warning"></i>Risk Assessment
                        </h5>
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <span class="badge risk-badge bg-@Model.RiskColor fs-6 px-3 py-2">
                                <i class="bi bi-shield-exclamation me-1"></i>@Model.RiskLevel Risk
                            </span>
                        </div>
                        <div class="risk-meter mb-3">
                            <div class="risk-meter-track">
                                <div class="risk-meter-fill bg-@Model.RiskColor" style="width: @Model.RiskPercent%;"></div>
                            </div>
                            <div class="d-flex justify-content-between mt-1">
                                <span class="x-small text-muted">Low</span>
                                <span class="x-small text-muted">Medium</span>
                                <span class="x-small text-muted">High</span>
                            </div>
                        </div>
                        <div class="alert alert-warning border-0 small mb-0 d-flex align-items-start gap-2">
                            <i class="bi bi-cloud-lightning text-warning mt-1"></i>
                            <span>@Model.RiskExplanation</span>
                        </div>
                    </div>
                </div>

                <!-- Treatment Recommendation Card -->
                <div class="card result-card mt-4 fade-in" style="animation-delay: 0.5s;">
                    <div class="card-body p-4">
                        <h5 class="card-title fw-bold mb-4">
                            <i class="bi bi-prescription2 me-2 text-accent"></i>Treatment Recommendations
                        </h5>

                        <!-- Organic -->
                        <div class="treatment-section mb-4">
                            <h6 class="fw-bold d-flex align-items-center gap-2 mb-3">
                                <span class="treatment-icon bg-success-subtle text-success">
                                    <i class="bi bi-flower1"></i>
                                </span>
                                Organic Treatment
                            </h6>
                            <ul class="treatment-list">
                                @foreach (var item in Model.OrganicTreatment)
                                {
                                    <li>@item</li>
                                }
                            </ul>
                        </div>

                        <!-- Chemical -->
                        <div class="treatment-section mb-4">
                            <h6 class="fw-bold d-flex align-items-center gap-2 mb-3">
                                <span class="treatment-icon bg-primary-subtle text-primary">
                                    <i class="bi bi-capsule"></i>
                                </span>
                                Chemical Treatment
                            </h6>
                            <ul class="treatment-list">
                                @foreach (var item in Model.ChemicalTreatment)
                                {
                                    <li>@item</li>
                                }
                            </ul>
                        </div>

                        <!-- Preventive -->
                        <div class="treatment-section">
                            <h6 class="fw-bold d-flex align-items-center gap-2 mb-3">
                                <span class="treatment-icon bg-info-subtle text-info">
                                    <i class="bi bi-shield-plus"></i>
                                </span>
                                Preventive Measures
                            </h6>
                            <ul class="treatment-list">
                                @foreach (var item in Model.PreventiveMeasures)
                                {
                                    <li>@item</li>
                                }
                            </ul>
                        </div>

                    </div>
                </div>

            </div>
        </div>

        <!-- Print / Download Hint -->
        <div class="text-center mt-5 fade-in" style="animation-delay: 0.6s;">
            <button class="btn btn-outline-secondary me-2" onclick="window.print()">
                <i class="bi bi-printer me-1"></i>Print Report
            </button>
            <a class="btn btn-primary-agri" asp-controller="Home" asp-action="Index">
                <i class="bi bi-arrow-repeat me-1"></i>Analyze Another Crop
            </a>
        </div>

    </div>
</section>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // Show success toast if coming from analysis
            showToast('Analysis completed successfully!', 'success');

            // Text-to-Speech logic
            const synthesis = window.speechSynthesis;
            const voiceSelect = document.getElementById('voiceSelect');
            let voices = [];

            // Build the comprehensive text including treatments
            const orgTreatments = "@Html.Raw(string.Join(", ", Model.OrganicTreatment))";
            const chemTreatments = "@Html.Raw(string.Join(", ", Model.ChemicalTreatment))";
            const prevMeasures = "@Html.Raw(string.Join(", ", Model.PreventiveMeasures))";
            
            let textToRead = "Analysis complete for your @Model.CropName. " +
                             "The detected disease is @Model.DiseaseName with a confidence of @Model.Confidence.ToString("F0") percent. " +
                             "The risk level is @Model.RiskLevel. " +
                             "@Model.RiskExplanation. ";
            
            if (orgTreatments && orgTreatments !== "None") {
                textToRead += "For organic treatment, we recommend " + orgTreatments + ". ";
            }
            if (chemTreatments && chemTreatments !== "None") {
                textToRead += "For chemical treatment, " + chemTreatments + ". ";
            }
            if (prevMeasures && prevMeasures !== "None") {
                textToRead += "As a preventive measure, " + prevMeasures + ".";
            }

            function populateVoiceList() {
                if (!synthesis) return;
                voices = synthesis.getVoices();
                if (voices.length === 0) return;

                // Clear default option
                voiceSelect.innerHTML = '';
                
                voices.forEach((voice, i) => {
                    const option = document.createElement('option');
                    option.textContent = `${voice.name} (${voice.lang})`;
                    
                    if (voice.default) {
                        option.textContent += ' — Default';
                    }
                    
                    option.setAttribute('data-lang', voice.lang);
                    option.setAttribute('data-name', voice.name);
                    voiceSelect.appendChild(option);
                });
            }

            // Populate voices (Safari/Chrome handle onvoiceschanged differently)
            populateVoiceList();
            if (speechSynthesis.onvoiceschanged !== undefined) {
                speechSynthesis.onvoiceschanged = populateVoiceList;
            }

            function readAloud() {
                if (!synthesis) {
                    console.warn("Text-to-speech not supported in this browser.");
                    return;
                }

                synthesis.cancel(); // Stop playing

                const utterance = new SpeechSynthesisUtterance(textToRead);
                
                // Assign selected voice
                const selectedOption = voiceSelect.selectedOptions[0]?.getAttribute('data-name');
                if (selectedOption) {
                    const selectedVoice = voices.find(v => v.name === selectedOption);
                    if (selectedVoice) {
                        utterance.voice = selectedVoice;
                        utterance.lang = selectedVoice.lang; // Override to match the voice
                    }
                } else {
                    utterance.lang = 'en-US';
                }
                
                utterance.rate = 1.0;
                utterance.pitch = 1.0;

                synthesis.speak(utterance);
            }

            // Attempt to read immediately on load
            setTimeout(readAloud, 500);

            // Bind Replay Button
            const replayBtn = document.getElementById('btnReplayAudio');
            if (replayBtn) {
                replayBtn.addEventListener('click', readAloud);
            }
            
            // Replay immediately if the user changes the voice
            if (voiceSelect) {
                voiceSelect.addEventListener('change', readAloud);
            }
        });
    </script>
}
