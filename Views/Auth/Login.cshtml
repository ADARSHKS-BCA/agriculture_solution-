@model Agriculture.Models.LoginViewModel
@{
    ViewData["Title"] = "Log In";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-body p-5">
                <div class="text-center mb-4">
                    <i class="bi bi-shield-lock text-primary fs-1 mb-3"></i>
                    <h2 class="fw-bold">Welcome Back</h2>
                    <p class="text-muted">Sign in to your account</p>
                </div>
                
                @if (TempData["SignupSuccess"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show rounded-3" role="alert">
                        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SignupSuccess"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <form asp-controller="Auth" asp-action="Login" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small fw-semibold"></div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-semibold">Email address</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-envelope text-muted"></i></span>
                            <input asp-for="Email" class="form-control border-start-0 ps-0" placeholder="name@example.com" required>
                        </div>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <div class="d-flex justify-content-between">
                            <label asp-for="Password" class="form-label fw-semibold">Password</label>
                        </div>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-end-0"><i class="bi bi-key text-muted"></i></span>
                            <input asp-for="Password" type="password" class="form-control border-start-0 ps-0" placeholder="Enter your password" required>
                        </div>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="d-grid mb-4">
                        <button type="submit" class="btn btn-primary btn-lg rounded-pill shadow-sm fw-bold">
                            Sign In
                        </button>
                    </div>

                    <div class="text-center text-muted small">
                        Don't have an account? <a asp-controller="Auth" asp-action="Signup" class="fw-semibold text-decoration-none">Sign up for free</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
