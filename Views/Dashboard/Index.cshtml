@model Agriculture.Models.DashboardViewModel
@using Agriculture.Models
@{
    ViewData["Title"] = "Dashboard";
    var userName = Model.UserProfile?.Username ?? User.Identity?.Name ?? "User";
}

<div class="container py-5">
    <!-- Header -->
    <div class="row mb-5 align-items-center">
        <div class="col-md-8">
            <h1 class="fw-bold fs-3 text-dark mb-1">Welcome, @userName</h1>
            <p class="text-muted mb-0">Overview of your agricultural scans and risk assessments.</p>
        </div>
        <div class="col-md-4 text-md-end mt-3 mt-md-0">
             <a href="/Scan/Index" class="btn btn-dark fw-semibold px-4 rounded-1">New Scan</a>
        </div>
    </div>

    <!-- Summary Cards -->
    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-2 h-100">
                <div class="card-body p-4">
                    <p class="text-muted fw-medium small text-uppercase tracking-wide mb-2">Total Scans</p>
                    <h2 class="fw-bold text-dark mb-0">@Model.TotalScans</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-2 h-100">
                <div class="card-body p-4 border-start border-danger border-4">
                    <p class="text-muted fw-medium small text-uppercase tracking-wide mb-2">High Risk Cases</p>
                    <h2 class="fw-bold text-dark mb-0">@Model.HighRiskCases</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-2 h-100">
                <div class="card-body p-4 border-start border-warning border-4">
                    <p class="text-muted fw-medium small text-uppercase tracking-wide mb-2">Moderate Risk Cases</p>
                    <h2 class="fw-bold text-dark mb-0">@Model.ModerateRiskCases</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-2 h-100">
                <div class="card-body p-4 border-start border-success border-4">
                    <p class="text-muted fw-medium small text-uppercase tracking-wide mb-2">Low Risk Cases</p>
                    <h2 class="fw-bold text-dark mb-0">@Model.LowRiskCases</h2>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Recent Activity Table -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-2 h-100">
                <div class="card-body p-0">
                    <div class="p-4 border-bottom">
                         <h5 class="fw-bold text-dark mb-0">Recent Activity</h5>
                    </div>
                    
                    @if (Model.RecentActivity.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light text-muted small text-uppercase">
                                    <tr>
                                        <th class="ps-4 fw-semibold py-3 border-0">Date</th>
                                        <th class="fw-semibold py-3 border-0">Crop</th>
                                        <th class="fw-semibold py-3 border-0">Disease</th>
                                        <th class="fw-semibold py-3 border-0">Risk Level</th>
                                        <th class="fw-semibold py-3 border-0">Confidence</th>
                                        <th class="pe-4 text-end fw-semibold py-3 border-0">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.RecentActivity)
                                    {
                                        <tr>
                                            <td class="ps-4 py-3 text-secondary small">
                                                @item.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy")
                                            </td>
                                            <td class="py-3">
                                                <span class="fw-medium text-dark">@item.Crop</span>
                                            </td>
                                            <td class="py-3 text-secondary">
                                                @(string.IsNullOrEmpty(item.Disease) ? "None Detected" : item.Disease)
                                            </td>
                                            <td class="py-3">
                                                @if (item.RiskLevel == "High")
                                                {
                                                    <span class="badge bg-danger bg-opacity-10 text-danger rounded-1 px-2 fw-medium">High</span>
                                                }
                                                else if (item.RiskLevel == "Medium")
                                                {
                                                    <span class="badge bg-warning bg-opacity-10 text-dark rounded-1 px-2 fw-medium">Moderate</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-success bg-opacity-10 text-success rounded-1 px-2 fw-medium">Low</span>
                                                }
                                            </td>
                                            <td class="py-3 text-secondary small">
                                                @($"{item.Confidence / 100:P1}")
                                            </td>
                                            <td class="pe-4 py-3 text-end">
                                                <a href="/Dashboard" class="btn btn-sm btn-light text-secondary rounded-1 px-3">View Details</a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="p-5 text-center">
                            <p class="text-muted mb-3">No scans found.</p>
                            <a href="/Scan/Index" class="btn btn-dark fw-semibold px-4 rounded-1">Create Your First Scan</a>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Quick Actions Sidebar -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-2 h-100">
                <div class="card-body p-4">
                    <h5 class="fw-bold text-dark mb-4">Quick Actions</h5>
                    <div class="d-grid gap-3">
                        <a href="/Scan/Index" class="btn btn-outline-dark text-start p-3 rounded-1 fw-medium border">
                            New Scan
                        </a>
                        <a href="/Dashboard/Index" class="btn btn-outline-dark text-start p-3 rounded-1 fw-medium border">
                            View History
                        </a>
                        <a href="#" class="btn btn-outline-dark text-start p-3 rounded-1 fw-medium border">
                            Profile
                        </a>
                        <a href="/Auth/Logout" class="btn btn-outline-danger text-start p-3 rounded-1 fw-medium border">
                            Logout
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
