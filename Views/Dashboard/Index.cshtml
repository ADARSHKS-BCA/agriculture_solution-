@model Agriculture.Models.DashboardViewModel
@using Agriculture.Models
@{
    ViewData["Title"] = "Scan History";
    var userName = Model.UserProfile?.Username ?? User.Identity?.Name ?? "User";
}

<div class="container py-5">
    <!-- Header -->
    <div class="row mb-5 align-items-center">
        <div class="col-md-8">
            <h1 class="fw-bold fs-3 text-dark mb-1">Scan History</h1>
            <p class="text-muted mb-0">Review all your previous agricultural risk assessments.</p>
        </div>
        <div class="col-md-4 text-md-end mt-3 mt-md-0">
             <a href="/Scan/Index" class="btn btn-primary-agri">New Scan</a>
        </div>
    </div>

    <div class="row g-4">
        <!-- Expanded History Table -->
        <div class="col-12">
            <div class="card border-0 shadow-sm rounded-2 h-100">
                <div class="card-body p-0">
                    <div class="p-4 border-bottom d-flex justify-content-between align-items-center bg-agri-bg-subtle">
                         <h5 class="fw-bold text-dark mb-0">Previous Scans</h5>
                         <span class="badge" style="background-color: var(--agri-accent); color: white;">Supabase Connected</span>
                    </div>
                    
                    @if (Model.History.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light text-muted small text-uppercase">
                                    <tr>
                                        <th class="ps-4 fw-semibold py-3 border-0">Date</th>
                                        <th class="fw-semibold py-3 border-0">Crop</th>
                                        <th class="fw-semibold py-3 border-0">Risk Level</th>
                                        <th class="fw-semibold py-3 border-0">Result Summary</th>
                                        <th class="pe-4 text-end fw-semibold py-3 border-0">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.History)
                                    {
                                        <tr>
                                            <td class="ps-4 py-3 text-secondary small">
                                                @item.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy HH:mm")
                                            </td>
                                            <td class="py-3">
                                                <span class="fw-medium text-dark">@item.CropType</span>
                                            </td>
                                            <td class="py-3">
                                                @if (item.RiskLevel == "High")
                                                {
                                                    <span class="badge bg-danger bg-opacity-10 text-danger rounded-1 px-2 fw-medium">High</span>
                                                }
                                                else if (item.RiskLevel == "Moderate" || item.RiskLevel == "Medium")
                                                {
                                                    <span class="badge bg-warning bg-opacity-10 text-dark rounded-1 px-2 fw-medium">Moderate</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-success bg-opacity-10 text-success rounded-1 px-2 fw-medium">Low</span>
                                                }
                                            </td>
                                            <td class="py-3 text-secondary small text-truncate" style="max-width: 350px;">
                                                @(string.IsNullOrEmpty(item.ResultSummary) ? "No summary available." : item.ResultSummary)
                                            </td>
                                            <td class="pe-4 py-3 text-end">
                                                <a href="/Dashboard" class="btn btn-sm btn-light text-secondary rounded-1 px-3">View Details</a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="p-5 text-center">
                            <p class="text-muted mb-3">No scans found in history.</p>
                            <a href="/Scan/Index" class="btn btn-primary-agri">Create Your First Scan</a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
