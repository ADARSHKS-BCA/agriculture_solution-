<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — AgriShield</title>
    <meta name="description" content="Crop disease early detection and risk prediction system for modern agriculture." />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Playfair+Display:ital,wght@0,400..900;1,400..900&display=swap" rel="stylesheet" />
    
    <!-- FontAwesome (For organic leafy icons) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <!-- Bootstrap 5.3 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />

    <!-- Site CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        .pulse-animation {
            animation: pulse-red 1.5s infinite;
        }
        @@keyframes pulse-red {
            0% { transform: scale(1); opacity: 1; }
            50% { transform: scale(1.2); opacity: 0.7; }
            100% { transform: scale(1); opacity: 1; }
        }
    </style>

    <!-- Page-Specific Styles -->
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg border-bottom sticky-top py-3 navbar-dark navbar-agri" style="backdrop-filter: blur(12px); background-color: rgba(26,54,34, 0.95) !important;">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center text-white text-decoration-none" asp-controller="Home" asp-action="Index">
                <i class="fa-solid fa-leaf text-accent me-2"></i>
                <span class="fs-4 tracking-tight">AgriShield</span>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMain">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navMain">
                <ul class="navbar-nav ms-auto align-items-center gap-2 fw-medium text-secondary">
                    @if (User.Identity?.IsAuthenticated == true)
                    {

                        <li class="nav-item">
                            <a class="nav-link px-3" asp-controller="Scan" asp-action="Index">
                                <i class="fa-solid fa-camera me-1"></i> Scan
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3" asp-controller="FarmWallet" asp-action="Index">Farm Wallet</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3" asp-controller="Profile" asp-action="Index">Profile</a>
                        </li>
                        <li class="nav-item ms-2">
                            <a class="btn btn-secondary-agri btn-sm px-4 fw-semibold rounded-1" asp-controller="Auth" asp-action="Logout">Logout</a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-medium" asp-area="" asp-controller="Scan" asp-action="Index">Scan</a>
                        </li>
                        <li class="nav-item ms-2">
                            <a class="btn btn-dark btn-sm px-4 fw-semibold rounded-1" asp-controller="Auth" asp-action="Signup">Sign up</a>
                        </li>
                    }
                    <!-- Voice Command Button -->
                    <li class="nav-item ms-3 border-start ps-3 d-flex align-items-center">
                        <button id="btnVoiceCommand" class="btn btn-outline-dark btn-sm rounded-circle d-flex align-items-center justify-content-center" style="width: 36px; height: 36px;" title="Start Voice Commands">
                            <i id="iconVoiceCommand" class="bi bi-mic" style="font-size: 1.1rem;"></i>
                        </button>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Loading Overlay -->
    <div id="loadingOverlay" class="loading-overlay d-none">
        <div class="text-center">
            <div class="spinner-border text-light mb-3" style="width: 3rem; height: 3rem;" role="status">
                <span class="visually-hidden">Analyzing...</span>
            </div>
            <p class="text-light fs-5 fw-semibold">Analyzing crop image...</p>
        </div>
    </div>

    <!-- Toast Container -->
    <div class="toast-container position-fixed top-0 end-0 p-3" id="toastContainer" style="z-index:1090;"></div>

    <!-- Main -->
    <main class="flex-grow-1">
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="bg-white border-top text-center py-4 mt-auto">
        <div class="container">
            <p class="mb-0 text-muted small">AgriShield &copy; 2025</p>
        </div>
    </footer>

    <!-- jQuery (Required for ASP.NET Validation) -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Site JS -->
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/voiceCommand.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
